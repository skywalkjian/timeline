{
  "manifest_version": 3,
  "name": "timeline",
  "version": "0.1.0",
  "description": "Send active tab domain events to the local timeline agent.",
  "permissions": [
    "tabs",
    "windows",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "timeline"
  }
}
